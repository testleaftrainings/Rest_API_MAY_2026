  "item": [
    {
      "name": "create_new_record_in_incident_table_with_request_body",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "\tpm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Status code name has Created\", function () {\r",
              "\tpm.response.to.have.status(\"Created\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the value of short_description key\", function () {\r",
              "\tvar jsonData = pm.response.json();\r",
              "\tpm.expect(jsonData.result.short_description).to.eql(pm.iterationData.get(\"ShortDescription\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the value of description key\", function () {\r",
              "\tvar jsonData = pm.response.json();\r",
              "\tpm.expect(jsonData.result.description).to.eql(pm.iterationData.get(\"Description\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the value of Category key\", function () {\r",
              "\tvar jsonData = pm.response.json();\r",
              "\tpm.expect(jsonData.result.category).to.eql(pm.iterationData.get(\"Category\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Validate response format is json\", function () {\r",
              "\tvar actual = pm.response.headers.get(\"Content-Type\");\r",
              "\tpm.expect(actual).to.contains('json');\r",
              "});\r",
              "\r",
              "pm.test(\"Validate sys_id key should exists under result object\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.result).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Validate sys_id value should not be NULL\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.result.sys_id).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Validate sys_id value should not empty\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.result.sys_id).to.not.eql(\"\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
